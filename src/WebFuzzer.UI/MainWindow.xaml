<ui:FluentWindow x:Class="WebFuzzer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="WebFuzzer" Height="800" Width="1300"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Default"
        FontFamily="Consolas" MinWidth="1000" MinHeight="600">

    <ui:FluentWindow.Resources>
        <!-- Tiêu đề section: dùng màu accent của hệ thống -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
        </Style>
        <!-- Field label: màu rõ, không mờ nhạt -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ui:TitleBar Title="WebFuzzer v1.0" Grid.Row="0" Margin="4,4,4,0"/>

        <Grid Grid.Row="1" Margin="12,12,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="240" MaxWidth="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <ui:Card Grid.Column="0" Margin="0,0,12,0" Padding="0" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <!-- Target -->
                        <TextBlock Text="🎯 TARGET" Style="{StaticResource SectionHeader}"/>
                        
                        <TextBlock Text="URL" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtUrl" Text="https://example.com/FUZZ" PlaceholderText="Target URL" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="Wordlist" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="TxtWordlist" Text="wordlists/common.txt"/>
                            <ui:Button Grid.Column="1" Click="BrowseWordlist_Click" Margin="4,0,0,0" Icon="{ui:SymbolIcon Folder20}"/>
                        </Grid>

                        <TextBlock Text="HTTP Method" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbMethod" SelectedIndex="0" Margin="0,0,0,24" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                            <ComboBoxItem Content="PUT"/>
                            <ComboBoxItem Content="DELETE"/>
                            <ComboBoxItem Content="PATCH"/>
                            <ComboBoxItem Content="HEAD"/>
                        </ComboBox>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Match / Filter -->
                        <TextBlock Text="🔍 MATCH &amp; FILTER" Style="{StaticResource SectionHeader}"/>
                        
                        <TextBlock Text="Match Codes (-mc)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtMatchCodes" Text="200,301,302" Margin="0,0,0,12"/>

                        <TextBlock Text="Filter Codes (-fc)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtFilterCodes" Text="404" Margin="0,0,0,12"/>

                        <TextBlock Text="Filter Size (-fs)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtFilterSize" PlaceholderText="e.g. 416" Margin="0,0,0,12"/>

                        <TextBlock Text="Match Regex (-mr)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtMatchRegex" PlaceholderText="regex" Margin="0,0,0,12"/>

                        <TextBlock Text="Filter Regex (-fr)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtFilterRegex" PlaceholderText="regex" Margin="0,0,0,24"/>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Performance -->
                        <TextBlock Text="⚡ PERFORMANCE" Style="{StaticResource SectionHeader}"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Threads" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="TxtThreads" Text="40"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Timeout(s)" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="TxtTimeout" Text="10"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Rate Limit (0=∞)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtRate" Text="0" Margin="0,0,0,24"/>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Options -->
                        <TextBlock Text="⚙ OPTIONS" Style="{StaticResource SectionHeader}"/>
                        
                        <CheckBox x:Name="ChkAutoCalibrate" Content="Auto-Calibrate" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkVerbose" Content="Verbose" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkFollowRedirects" Content="Follow Redirects" Margin="0,0,0,16"/>

                        <TextBlock Text="Proxy" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtProxy" PlaceholderText="http://127.0.0.1:8080" Margin="0,0,0,12"/>

                        <TextBlock Text="Custom Header" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtHeader" PlaceholderText="Auth: Bearer ..." Margin="0,0,0,12"/>

                        <TextBlock Text="POST Data" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtData" PlaceholderText="user=admin" Margin="0,0,0,24"/>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Output -->
                        <TextBlock Text="📁 OUTPUT" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Save Results To" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="TxtOutputFile" PlaceholderText="None"/>
                            <ui:Button Grid.Column="1" Click="BrowseOutput_Click" Margin="4,0,0,0" Icon="{ui:SymbolIcon Save20}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </ui:Card>

            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Command Preview Bar -->
                <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="12">
                     <Grid>
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="Auto"/>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                         </Grid.ColumnDefinitions>
                         <ui:SymbolIcon Symbol="Code16" Margin="0,0,10,0" Opacity="0.7"/>
                         <TextBlock Grid.Column="1" x:Name="TxtCommandPreview" 
                                    Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                    VerticalAlignment="Center"
                                    TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                         <ui:Button Grid.Column="2" Click="CopyCommand_Click" Content="Copy" Icon="{ui:SymbolIcon Copy16}" Margin="12,0,0,0" Padding="12,4" FontSize="11"/>
                     </Grid>
                </ui:Card>

                <!-- Action Bar -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <ui:Button Grid.Column="0" x:Name="BtnRun" Content="RUN FUZZER" Click="BtnRun_Click" Appearance="Primary" Icon="{ui:SymbolIcon Play20}" Margin="0,0,8,0" Padding="24,8" FontSize="14" FontWeight="Bold"/>
                    <ui:Button Grid.Column="1" x:Name="BtnStop" Content="STOP" Click="BtnStop_Click" Appearance="Danger" IsEnabled="False" Icon="{ui:SymbolIcon Stop20}" Margin="0,0,8,0" Padding="16,8" FontSize="14"/>
                    <ui:Button Grid.Column="2" Content="Clear" Click="BtnClear_Click" Icon="{ui:SymbolIcon Delete20}" Padding="16,8" FontSize="14"/>

                    <!-- Stats -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="Requests:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatRequests" Text="0" FontWeight="Bold" FontSize="14" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        
                        <TextBlock Text="Matches:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatMatches" Text="0" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource SystemFillColorSuccessBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        
                        <TextBlock Text="Req/s:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatRps" Text="0" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource SystemFillColorCautionBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Status -->
                    <Border Grid.Column="4" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="16,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtStatus" Text="IDLE" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Results & Terminal Split -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <!-- Results DataGrid -->
                    <ui:Card Grid.Row="0" Margin="0" Padding="0" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="16,10" Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Table20" Margin="0,0,8,0"/>
                                        <TextBlock Text="RESULTS" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <ui:Button Content="Export JSON" Click="ExportJson_Click" Margin="0,0,8,0" Padding="10,4" FontSize="11" Icon="{ui:SymbolIcon DocumentArrowDown20}"/>
                                        <ui:Button Content="Export CSV" Click="ExportCsv_Click" Padding="10,4" FontSize="11" Icon="{ui:SymbolIcon DocumentArrowDown20}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="ResultsGrid" 
                                      AutoGenerateColumns="False" IsReadOnly="True" 
                                      BorderThickness="0" Background="Transparent"
                                      RowBackground="Transparent" AlternatingRowBackground="{DynamicResource ControlFillColorSecondaryBrush}"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                      HeadersVisibility="Column" SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusCode}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="200">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="403">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="404">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Word / Path" Binding="{Binding Word}" Width="160" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Size" Binding="{Binding ContentLength}" Width="80"/>
                                    <DataGridTextColumn Header="Words" Binding="{Binding WordCount}" Width="80"/>
                                    <DataGridTextColumn Header="Lines" Binding="{Binding LineCount}" Width="80"/>
                                    <DataGridTextColumn Header="Time (ms)" Binding="{Binding DurationMs}" Width="80"/>
                                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </ui:Card>

                    <!-- Splitter -->
                    <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"/>

                    <!-- Terminal -->
                    <ui:Card Grid.Row="2" Margin="0" Padding="0" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                         <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="16,10" Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Code20" Margin="0,0,8,0"/>
                                        <TextBlock Text="TERMINAL OUTPUT" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ui:Button Content="Clear" Click="ClearTerminal_Click" HorizontalAlignment="Right" Padding="10,4" FontSize="11" Icon="{ui:SymbolIcon Delete16}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" x:Name="TerminalScroll" Background="#050505" Padding="12">
                                <TextBlock x:Name="TxtTerminal" Foreground="#A0A0A0" TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </ui:Card>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
