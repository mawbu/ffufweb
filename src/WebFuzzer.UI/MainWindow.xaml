<ui:FluentWindow x:Class="WebFuzzer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="WebFuzzer" Height="800" Width="1400"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        WindowCornerPreference="Default"
        WindowStyle="None"
        FontFamily="Consolas" MinWidth="1000" MinHeight="600">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>

        <!-- Row style theo severity -->
        <Style x:Key="SeverityRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RowSeverity}" Value="Confirmed">
                    <Setter Property="Background" Value="#22FF3B30"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RowSeverity}" Value="Likely">
                    <Setter Property="Background" Value="#22FF8C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RowSeverity}" Value="Suspicious">
                    <Setter Property="Background" Value="#22FFD700"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Style cho signal chip trong Detail Panel -->
        <Style x:Key="SignalChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ui:TitleBar Title="WebFuzzer v1.0" Grid.Row="0" Margin="4,4,4,0"/>

        <Grid Grid.Row="1" Margin="12,12,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="240" MaxWidth="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <ui:Card Grid.Column="0" Margin="0,0,12,0" Padding="0" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <!-- Target -->
                        <TextBlock Text="🎯 TARGET" Style="{StaticResource SectionHeader}"/>
                        
                        <TextBlock Text="URL" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtUrl" Text="https://example.com/FUZZ" PlaceholderText="Target URL" Margin="0,0,0,12"/>
                        
                        <!-- ✅ MỚI: SQL Payload Mode -->
                        <TextBlock Text="Wordlist / SQL Payload" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="TxtWordlist" Text="wordlists/common.txt"/>
                            <ui:Button Grid.Column="1" Click="BrowseWordlist_Click" Margin="4,0,0,0" Icon="{ui:SymbolIcon Folder20}"/>
                        </Grid>
                        <!-- ✅ Quick payload selector -->
                        <ComboBox x:Name="CmbSqlPayload" Margin="0,0,0,12" HorizontalAlignment="Stretch"
                                  SelectionChanged="CmbSqlPayload_SelectionChanged"
                                  ToolTip="Chọn nhanh wordlist theo loại tấn công">
                            <ComboBoxItem Content="-- Chọn Wordlist --" IsSelected="True" Tag=""/>
                            <ComboBoxItem Content="🔴 SQLi Generic (sqli.txt)" Tag="wordlists/sqli.txt"/>
                            <ComboBoxItem Content="🟠 SQLi JSON (sqli.json)" Tag="wordlists/sqli.json"/>
                            <ComboBoxItem Content="🟠 SQLi Extended (abc.json)" Tag="wordlists/abc.json"/>
                            <ComboBoxItem Content="🟠 SQLi Extended 2 (bcd.json)" Tag="wordlists/bcd.json"/>
                            <ComboBoxItem Content="🟡 XSS Generic (xss.txt)" Tag="wordlists/xss.txt"/>
                            <ComboBoxItem Content="🟡 XSS JSON (HTTPxss.json)" Tag="wordlists/HTTPxss.json"/>
                            <ComboBoxItem Content="🟢 Common paths" Tag="wordlists/common.txt"/>
                            <ComboBoxItem Content="🔵 API endpoints" Tag="wordlists/api-endpoints.txt"/>
                            <ComboBoxItem Content="🔵 4-digit IDs" Tag="wordlists/4-digits-0000-9999.txt"/>
                        </ComboBox>

                        <TextBlock Text="HTTP Method" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CmbMethod" SelectedIndex="0" Margin="0,0,0,24" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="GET"/>
                            <ComboBoxItem Content="POST"/>
                            <ComboBoxItem Content="PUT"/>
                            <ComboBoxItem Content="DELETE"/>
                            <ComboBoxItem Content="PATCH"/>
                            <ComboBoxItem Content="HEAD"/>
                        </ComboBox>

                        <Separator Margin="0,0,0,16"/>

                        <!-- ✅ MỚI: IDOR Section -->
                        <TextBlock Text="🔁 IDOR / URL SCAN" Style="{StaticResource SectionHeader}"/>
                        <CheckBox x:Name="ChkIdorMode" Content="IDOR Mode (scan URL range)" Margin="0,0,0,8"
                                  ToolTip="Tạo nhiều URL từ URL gốc bằng cách thay FUZZ bằng dải số"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ID From" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="TxtIdorFrom" Text="1" IsEnabled="{Binding IsChecked, ElementName=ChkIdorMode}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Bottom" Margin="6,0,6,8" Opacity="0.6"/>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ID To" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="TxtIdorTo" Text="100" IsEnabled="{Binding IsChecked, ElementName=ChkIdorMode}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="(URL phải chứa FUZZ — ví dụ: /api/user/FUZZ)" 
                                   Opacity="0.5" FontSize="10" Margin="0,2,0,16" TextWrapping="Wrap"/>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Match / Filter -->
                        <TextBlock Text="🔍 MATCH &amp; FILTER" Style="{StaticResource SectionHeader}"/>
                        
                        <TextBlock Text="Match Codes (-mc)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtMatchCodes" Text="200,301,302" Margin="0,0,0,12"/>

                        <TextBlock Text="Filter Codes (-fc)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtFilterCodes" Text="404" Margin="0,0,0,12"/>

                        <TextBlock Text="Filter Size (-fs)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtFilterSize" PlaceholderText="e.g. 416" Margin="0,0,0,12"/>

                        <TextBlock Text="Match Regex (-mr)" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="TxtMatchRegex" PlaceholderText="regex pattern in body"/>
                            <ui:Button Grid.Column="1" x:Name="BtnPreset" Content="Preset" 
                                       Click="BtnPreset_Click" Margin="4,0,0,0" Padding="8,4" FontSize="11"
                                       Icon="{ui:SymbolIcon LightbulbCircle20}" ToolTip="Error Detection Presets"/>
                        </Grid>
                        <ComboBox x:Name="CmbErrorPreset" Margin="0,0,0,12" HorizontalAlignment="Stretch"
                                  SelectionChanged="CmbErrorPreset_SelectionChanged">
                            <ComboBoxItem Content="-- Chọn Error Preset --" IsSelected="True" Tag=""/>
                            <ComboBoxItem Content="🔴 SQLi Error (SQL syntax, SQLITE)" Tag="SQLITE_ERROR|syntax error|SQLiteException|ORA-\d+|mysql_fetch|pg_query"/>
                            <ComboBoxItem Content="🔴 Auth Bypass (token, admin)" Tag="token|&quot;role&quot;:&quot;admin&quot;|authentication|bearer"/>
                            <ComboBoxItem Content="🟡 Server Error (500, exception)" Tag="Internal Server Error|exception|stack trace|Traceback|NullPointerException"/>
                            <ComboBoxItem Content="🟡 Path Traversal (root, etc)" Tag="root:x:|boot\.ini|\[extensions\]|&lt;!DOCTYPE"/>
                            <ComboBoxItem Content="🟢 XSS Reflected (payload echo)" Tag="alert\(|onerror=|onload=|javascript:"/>
                            <ComboBoxItem Content="🟢 Info Disclosure (version, debug)" Tag="version|debug|password|secret|api.key|config"/>
                            <ComboBoxItem Content="🔵 IDOR (found user data)" Tag="&quot;email&quot;|&quot;username&quot;|&quot;role&quot;|&quot;id&quot;:\d"/>
                        </ComboBox>

                        <TextBlock Text="Filter Regex (-fr)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtFilterRegex" PlaceholderText="regex" Margin="0,0,0,24"/>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Performance -->
                        <TextBlock Text="⚡ PERFORMANCE" Style="{StaticResource SectionHeader}"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Threads" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="TxtThreads" Text="40"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                <TextBlock Text="Timeout(s)" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="TxtTimeout" Text="10"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Rate Limit (0=∞)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtRate" Text="0" Margin="0,0,0,24"/>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Options -->
                        <TextBlock Text="⚙ OPTIONS" Style="{StaticResource SectionHeader}"/>
                        
                        <CheckBox x:Name="ChkAutoCalibrate" Content="Auto-Calibrate" IsChecked="True" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkVerbose" Content="Verbose" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkFollowRedirects" Content="Follow Redirects" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ChkSmartDetection" Content="☑ Smart Detection" IsChecked="True"
                                  Margin="0,0,0,8"
                                  ToolTip="Tự động phân tích và chấm điểm vulnerability sau mỗi request"/>
                        <CheckBox x:Name="ChkEnableConfirmation" Content="✅ Auto-Retest (High Precision)" IsChecked="True"
                                  Margin="0,0,0,16"
                                  ToolTip="Gửi thêm request đối chứng để loại bỏ báo động giả (SQLi, IDOR)"/>

                        <TextBlock Text="Proxy" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtProxy" PlaceholderText="http://127.0.0.1:8080" Margin="0,0,0,12"/>

                        <TextBlock Text="Custom Headers (1 header/line)" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtHeader" 
                                 PlaceholderText="Authorization: Bearer ..."
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="70" VerticalScrollBarVisibility="Auto"
                                 Padding="8,6" Margin="0,0,0,12"/>

                        <TextBlock Text="Content-Type" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtContentType" PlaceholderText="application/json" Margin="0,0,0,12"/>

                        <TextBlock Text="POST Data" Style="{StaticResource FieldLabel}"/>
                        <ui:TextBox x:Name="TxtData" PlaceholderText="user=admin" Margin="0,0,0,24"/>

                        <Separator Margin="0,0,0,16"/>

                        <!-- Output -->
                        <TextBlock Text="📁 OUTPUT" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Save Results To" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="TxtOutputFile" PlaceholderText="None"/>
                            <ui:Button Grid.Column="1" Click="BrowseOutput_Click" Margin="4,0,0,0" Icon="{ui:SymbolIcon Save20}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </ui:Card>

            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Command Preview Bar -->
                <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="12">
                     <Grid>
                         <Grid.ColumnDefinitions>
                             <ColumnDefinition Width="Auto"/>
                             <ColumnDefinition Width="*"/>
                             <ColumnDefinition Width="Auto"/>
                         </Grid.ColumnDefinitions>
                         <ui:SymbolIcon Symbol="Code16" Margin="0,0,10,0" Opacity="0.7"/>
                         <TextBlock Grid.Column="1" x:Name="TxtCommandPreview" 
                                    Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                    VerticalAlignment="Center"
                                    TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                         <ui:Button Grid.Column="2" Click="CopyCommand_Click" Content="Copy" Icon="{ui:SymbolIcon Copy16}" Margin="12,0,0,0" Padding="12,4" FontSize="11"/>
                     </Grid>
                </ui:Card>

                <!-- Action Bar -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <ui:Button Grid.Column="0" x:Name="BtnRun" Content="RUN FUZZER" Click="BtnRun_Click" Appearance="Primary" Icon="{ui:SymbolIcon Play20}" Margin="0,0,8,0" Padding="24,8" FontSize="14" FontWeight="Bold"/>
                    <ui:Button Grid.Column="1" x:Name="BtnStop" Content="STOP" Click="BtnStop_Click" Appearance="Danger" IsEnabled="False" Icon="{ui:SymbolIcon Stop20}" Margin="0,0,8,0" Padding="16,8" FontSize="14"/>
                    <ui:Button Grid.Column="2" Content="Clear" Click="BtnClear_Click" Icon="{ui:SymbolIcon Delete20}" Padding="16,8" FontSize="14"/>

                    <!-- Stats -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="Requests:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatRequests" Text="0" FontWeight="Bold" FontSize="14" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        
                        <TextBlock Text="Matches:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatMatches" Text="0" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource SystemFillColorSuccessBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>

                        <TextBlock Text="Vulns:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatVulns" Text="0" FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        
                        <TextBlock Text="Req/s:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatRps" Text="0" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource SystemFillColorCautionBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Status -->
                    <Border Grid.Column="4" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6" Padding="16,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtStatus" Text="IDLE" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Results, Detail Panel & Terminal -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto" x:Name="DetailPanelRow"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*" MinHeight="80"/>
                    </Grid.RowDefinitions>

                    <!-- Results DataGrid -->
                    <ui:Card Grid.Row="0" Margin="0" Padding="0" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="12,8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <Grid>
                                    <StackPanel Orientation="Vertical">
                                        <!-- Row 1: Title + Filters + Export -->
                                        <Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Table20" Margin="0,0,8,0"/>
                                                <TextBlock Text="RESULTS" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <TextBlock Text="|" Opacity="0.3" Margin="12,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Filter:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="11"/>
                                                <ComboBox x:Name="CmbSeverityFilter" SelectedIndex="0"
                                                          SelectionChanged="CmbSeverityFilter_SelectionChanged"
                                                          Padding="6,3" FontSize="11" VerticalAlignment="Center">
                                                    <ComboBoxItem Content="All"/>
                                                    <ComboBoxItem Content="🔴 Confirmed"/>
                                                    <ComboBoxItem Content="🟠 Likely+"/>
                                                    <ComboBoxItem Content="🟡 Suspicious+"/>
                                                </ComboBox>
                                                <TextBlock Text="|" Opacity="0.3" Margin="12,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Status:" Opacity="0.6" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="11"/>
                                                <ComboBox x:Name="CmbStatusFilter" SelectedIndex="0"
                                                          SelectionChanged="CmbStatusFilter_SelectionChanged"
                                                          Padding="6,3" FontSize="11" VerticalAlignment="Center">
                                                    <ComboBoxItem Content="All Statuses"/>
                                                    <ComboBoxItem Content="✅ 2xx"/>
                                                    <ComboBoxItem Content="↪ 3xx"/>
                                                    <ComboBoxItem Content="⚠ 4xx"/>
                                                    <ComboBoxItem Content="🔥 5xx"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <ui:Button Content="Export JSON" Click="ExportJson_Click" Margin="0,0,8,0" Padding="10,4" FontSize="11" Icon="{ui:SymbolIcon DocumentArrowDown20}"/>
                                                <ui:Button Content="Export CSV" Click="ExportCsv_Click" Padding="10,4" FontSize="11" Icon="{ui:SymbolIcon DocumentArrowDown20}"/>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Row 2: Status Count Badges -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Border Background="#1A3FB950" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="✅ 2xx: " FontSize="11" Opacity="0.7"/>
                                                    <TextBlock x:Name="TxtBadge2xx" Text="0" FontSize="11" FontWeight="Bold" Foreground="#3FB950"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#1AF0E68C" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="↪ 3xx: " FontSize="11" Opacity="0.7"/>
                                                    <TextBlock x:Name="TxtBadge3xx" Text="0" FontSize="11" FontWeight="Bold" Foreground="#F0E68C"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#1AFF8C00" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⚠ 4xx: " FontSize="11" Opacity="0.7"/>
                                                    <TextBlock x:Name="TxtBadge4xx" Text="0" FontSize="11" FontWeight="Bold" Foreground="#FF8C00"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#1AFF3B30" CornerRadius="4" Padding="8,3">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔥 5xx: " FontSize="11" Opacity="0.7"/>
                                                    <TextBlock x:Name="TxtBadge5xx" Text="0" FontSize="11" FontWeight="Bold" Foreground="#FF3B30"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" x:Name="ResultsGrid" 
                                      AutoGenerateColumns="False" IsReadOnly="True" 
                                      BorderThickness="0" Background="Transparent"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="{DynamicResource ControlFillColorSecondaryBrush}"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                      HeadersVisibility="Column" SelectionMode="Single"
                                      RowStyle="{StaticResource SeverityRowStyle}"
                                      SelectionChanged="ResultsGrid_SelectionChanged">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="📋 Copy Payload" Click="CopyPayload_Click"/>
                                        <MenuItem Header="🔗 Copy URL" Click="CopyUrl_Click"/>
                                        <Separator/>
                                        <MenuItem Header="🌐 Open URL in Browser" Click="OpenUrl_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <!-- Cột Confidence & Verified Badge -->
                                    <DataGridTemplateColumn Header="Vuln / Conf" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="CheckmarkCircle20" Foreground="{DynamicResource SystemFillColorSuccessBrush}" 
                                                                   Visibility="{Binding IsVerified, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                   Margin="0,0,4,0" ToolTip="Verified by Auto-Retest"/>
                                                    <TextBlock Text="{Binding ConfidenceLabel}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Vulnerability" Binding="{Binding VulnType}" Width="90" FontWeight="SemiBold">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding VulnType}" Value="IDOR">
                                                        <Setter Property="Foreground" Value="Cyan"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding VulnType}" Value="SQLi">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusCode}" Width="65">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="200">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="500">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="403">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusCode}" Value="404">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Cột Payload -->
                                    <DataGridTextColumn Header="Payload" Binding="{Binding Payload}" Width="200" FontWeight="SemiBold">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FFFF6B6B"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="ToolTip" Value="{Binding Payload}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Size" Binding="{Binding ContentLength}" Width="65"/>
                                    <DataGridTextColumn Header="Words" Binding="{Binding WordCount}" Width="60" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="Lines" Binding="{Binding LineCount}" Width="55" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="Time (ms)" Binding="{Binding DurationMs}" Width="75"/>

                                    <!-- ✅ FIX: Cột URL hiển thị đầy đủ URL có payload -->
                                    <DataGridTextColumn Header="URL (with payload)" Binding="{Binding Url}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="ToolTip" Value="{Binding Url}"/>
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                
                                     <!-- Bug 3: Match Reason column -->
                                     <DataGridTextColumn Header="Match Reason" Binding="{Binding MatchReason}" Width="190">
                                         <DataGridTextColumn.ElementStyle>
                                             <Style TargetType="TextBlock">
                                                 <Setter Property="ToolTip" Value="{Binding MatchReason}"/>
                                                 <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                 <Setter Property="VerticalAlignment" Value="Center"/>
                                                 <Setter Property="Foreground" Value="#FFB0C4DE"/>
                                                 <Setter Property="FontSize" Value="11"/>
                                                 <Setter Property="FontFamily" Value="Consolas"/>
                                             </Style>
                                         </DataGridTextColumn.ElementStyle>
                                     </DataGridTextColumn>
                                 </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </ui:Card>

                    <!-- Splitter trên -->
                    <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"/>

                    <!-- Detail Panel — hiện khi click row có detection -->
                    <ui:Card Grid.Row="2" x:Name="DetailPanel" Margin="0,0,0,4" Padding="0"
                             Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1" Padding="16,8"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ShieldError20" Margin="0,0,8,0"/>
                                        <TextBlock Text="DETECTION DETAIL" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtDetailSummary" Margin="12,0,0,0"
                                                   VerticalAlignment="Center" Opacity="0.8" FontSize="12" Foreground="White"/>
                                        <Border Background="#3300FF00" CornerRadius="4" Margin="10,0,0,0" Padding="8,2" x:Name="BrdVerified" Visibility="Collapsed">
                                             <TextBlock x:Name="TxtConfirmation" FontSize="11" FontWeight="Bold" Foreground="#FF00FF00"/>
                                        </Border>
                                    </StackPanel>
                                    <ui:Button HorizontalAlignment="Right" Content="✕" Padding="8,2" FontSize="11"
                                               Click="CloseDetailPanel_Click"/>
                                </Grid>
                            </Border>

                            <!-- Signal list + InjectedBody -->
                            <StackPanel Grid.Row="1" Margin="12,8,12,8">
                                <!-- ✅ Bug 1+2: InjectedBody — hiện full POST body đã inject -->
                                <Border x:Name="BrdInjectedBody" Visibility="Collapsed"
                                        Background="#1AFF6B6B" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="💉 INJECTED BODY" FontSize="11" FontWeight="Bold"
                                                       Foreground="#FFFF6B6B" Margin="0,0,8,0"/>
                                            <TextBlock Text="(POST data với payload đã thay thế)" FontSize="10" Opacity="0.6"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtInjectedBody"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="#FFF0A0A0" TextWrapping="Wrap"
                                                   MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>

                                <!-- ✅ Bug 3: MatchReason -->
                                <Border x:Name="BrdMatchReason" Visibility="Collapsed"
                                        Background="#1A6B9EFF" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📌 MATCH REASON: " FontSize="11" FontWeight="Bold"
                                                   Foreground="#FF6B9EFF" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="TxtMatchReasonDetail"
                                                   FontFamily="Consolas" FontSize="12"
                                                   Foreground="#FFB0C4DE"/>
                                    </StackPanel>
                                </Border>

                                <!-- Detection signals -->
                                <ItemsControl x:Name="SignalList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SignalChip}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="3" Padding="5,2" Margin="0,0,8,0"
                                                            Background="{DynamicResource SystemAccentColorPrimaryBrush}">
                                                        <TextBlock Text="{Binding VulnType}" FontSize="10" FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Evidence}" FontSize="11"
                                                               Opacity="0.7" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                               ToolTip="{Binding Evidence}"/>
                                                    <Border Grid.Column="3" CornerRadius="3" Padding="6,2" Margin="8,0,0,0"
                                                            Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}">
                                                        <TextBlock FontSize="11" FontWeight="Bold"
                                                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}">
                                                            <TextBlock.Text>
                                                                <Binding Path="Weight" StringFormat="+{0}"/>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </ui:Card>

                    <!-- Splitter dưới -->
                    <GridSplitter Grid.Row="3" Height="8" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeNS"/>

                    <!-- Terminal -->
                    <ui:Card Grid.Row="4" Margin="0" Padding="0" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch">
                         <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Grid.Row="0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="16,10" Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Code20" Margin="0,0,8,0"/>
                                        <TextBlock Text="TERMINAL OUTPUT" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ui:Button Content="Clear" Click="ClearTerminal_Click" HorizontalAlignment="Right" Padding="10,4" FontSize="11" Icon="{ui:SymbolIcon Delete16}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" x:Name="TerminalScroll" Background="#050505" Padding="12">
                                <TextBlock x:Name="TxtTerminal" Foreground="#A0A0A0" TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </ui:Card>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
